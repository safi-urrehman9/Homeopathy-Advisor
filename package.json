{
  "name": "homeopathy-advisor",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:api": "python3 backend/wsgi.py",
    "dev:web": "npm --workspace frontend run dev",
